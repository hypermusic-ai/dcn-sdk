{
  "name": "dcn",
  "version": "0.1.0",
  "description": "Decentralized Creative Network JavaScript/TypeScript SDK",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist src/generated",
    "codegen": "tsx scripts/codegen.ts",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts --dts --format esm,cjs --sourcemap",
    "prepack": "npm run clean && npm run codegen && npm run build",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "openapi-typescript-codegen": "^0.29.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.1.0",
    "tsx": "^4.16.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^2.1.3"
  }
}
