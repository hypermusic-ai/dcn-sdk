{
  "name": "dcn",
  "version": "0.1.0",
  "description": "Decentralized Creative Network JavaScript/TypeScript SDK",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./worlds/runtime": {
      "import": {
        "types": "./dist/worlds/runtime.d.ts",
        "default": "./dist/worlds/runtime.js"
      },
      "require": {
        "types": "./dist/worlds/runtime.d.cts",
        "default": "./dist/worlds/runtime.cjs"
      }
    },
    "./worlds/host": {
      "import": {
        "types": "./dist/worlds/host.d.ts",
        "default": "./dist/worlds/host.js"
      },
      "require": {
        "types": "./dist/worlds/host.d.cts",
        "default": "./dist/worlds/host.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist src/generated",
    "codegen": "tsx scripts/codegen.ts",
    "codegen:bundle": "node scripts/bundle-openapi.mjs --spec-root ../submodules/dcn-api-spec --output build/openapi/dcn-sdk.openapi.json",
    "codegen:js": "npm run codegen:bundle && openapi --input build/openapi/dcn-sdk.openapi.json --output src/generated --client fetch --useUnionTypes --exportSchemas true --postfixServices Api --name DcnGeneratedClient",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts src/worlds/runtime.ts src/worlds/host.ts --dts --format esm,cjs --sourcemap",
    "prepack": "npm run clean && npm run codegen && npm run build",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "js-yaml": "^4.2.0",
    "openapi-typescript-codegen": "^0.29.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.1.0",
    "tsx": "^4.16.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^2.1.3"
  }
}
